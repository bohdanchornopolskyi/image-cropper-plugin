{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "payload-plugin-image-cropper": ["./src/index.ts"],
      "payload-plugin-image-cropper/client": ["./src/exports/client.ts"],
      "payload-plugin-image-cropper/utilities": ["./src/exports/utilities.ts"]
    },
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "rootDir": "./",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "emitDeclarationOnly": true,
    "target": "ES2022",
    "composite": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["./src/**/*.ts", "./src/**/*.tsx", "./dev/next-env.d.ts", ".next/dev/types/**/*.ts"]
}
